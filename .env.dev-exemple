# ── Cloudinary (requerido si usas media) ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Django (obligatorio) ───────────────────────────────────────────────────────
PRODUCTION=0
SECRET_KEY=generate-key-here_CHANGE-THIS

# Postgres: definido en docker-compose.yml (POSTGRES_*). No uses DATABASE_URL aquí.
# Opcionales: COLLECT_STATIC=1 | WAIT_DB_VERBOSE=1 | CREATE_DEFAULT_SUPERUSER=1
# Ver README → Variables de entorno
