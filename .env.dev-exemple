# ── Cloudinary ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Django ─────────────────────────────────────────────────────────────────────
PRODUCTION=0
SECRET_KEY=generate-key-here_CHANGE-THIS

# Postgres connection is defined in docker-compose.yml (POSTGRES_*).
# Do not set DATABASE_URL here — that is for Railway production only.
